# API (Railway tingting-api)
DATABASE_URL=postgresql://user:pass@host:5432/railway
JWT_SECRET=change-me-to-random-32-chars-minimum
SUPABASE_JWT_SECRET=your-supabase-project-jwt-secret
NODE_ENV=production
CORS_ORIGIN=https://your-web-service.up.railway.app
# Optional: 카카오 앱 ID (콘솔 > 앱 설정). 설정 시 다른 앱 토큰 거부
# KAKAO_APP_ID=1234567

# Web (Railway tingting-web) — build-time + runtime (app-config.json)
EXPO_PUBLIC_API_URL=https://your-api-service.up.railway.app
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
EXPO_PUBLIC_APK_DOWNLOAD_URL=https://expo.dev/artifacts/eas/ODxmgIHNQOck2OswiAttiT6dLNSNMcBUOcaqQnykjUE.apk
EXPO_PUBLIC_SITE_URL=https://your-site.up.railway.app
# 카카오 JavaScript 키 (웹 로그인). Redirect URI에 Web 도메인 등록 필요
EXPO_PUBLIC_KAKAO_JS_KEY=your-kakao-javascript-key
# EAS Update (GitHub Actions) — repo Secrets에 EXPO_TOKEN 설정
# https://expo.dev/accounts/[account]/settings/access-tokens

# Supabase Dashboard Auth settings:
# - Enable Confirm email
# - Add redirect URLs such as https://your-site.up.railway.app/auth-callback,
#   https://your-site.up.railway.app/reset-password,
#   tingting://auth-callback, and tingting://reset-password
#
# Email Templates (Dashboard > Authentication > Email Templates):
# Set the following Korean templates to send emails in Korean.
#
# [Confirm signup] Subject: TingTing 이메일 인증
# Body:
#   <h2>이메일 인증</h2>
#   <p>아래 링크를 클릭하여 이메일 인증을 완료해 주세요.</p>
#   <p><a href="{{ .ConfirmationURL }}">이메일 인증하기</a></p>
#
# [Magic Link] Subject: TingTing 로그인 링크
# Body:
#   <h2>로그인 링크</h2>
#   <p>아래 링크를 클릭하여 로그인하세요.</p>
#   <p><a href="{{ .ConfirmationURL }}">로그인하기</a></p>
#
# [Change Email] Subject: TingTing 이메일 변경 확인
# Body:
#   <h2>이메일 변경 확인</h2>
#   <p>아래 링크를 클릭하여 이메일 변경을 확인해 주세요.</p>
#   <p><a href="{{ .ConfirmationURL }}">이메일 변경 확인</a></p>
#
# [Reset Password] Subject: TingTing 비밀번호 재설정
# Body:
#   <h2>비밀번호 재설정</h2>
#   <p>아래 링크를 클릭하여 비밀번호를 재설정해 주세요.</p>
#   <p><a href="{{ .ConfirmationURL }}">비밀번호 재설정</a></p>

# Build-time (Metro / EAS) — copy to `.env` and restart Expo
EXPO_PUBLIC_API_URL=https://tingting-api-production.up.railway.app
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
EXPO_PUBLIC_SITE_URL=https://your-site.up.railway.app
EXPO_PUBLIC_KAKAO_JS_KEY=your-kakao-javascript-key

# Supabase Auth redirect URLs to allow in the dashboard:
# https://your-site.up.railway.app/auth-callback
# https://your-site.up.railway.app/reset-password
# tingting://auth-callback
# tingting://reset-password

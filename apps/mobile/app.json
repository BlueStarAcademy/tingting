{
  "expo": {
    "name": "TingTing",
    "slug": "tingting",
    "scheme": "tingting",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#312E81"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.tingting.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#312E81",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.bluestaracademy.tingting",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "static"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/69501247-adff-48eb-9eba-c424ddd9b5f0",
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "react-native-maps",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "GPS 퀘스트를 위해 위치 접근이 필요합니다."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "방문 기록과 사진 편집을 위해 사진 접근이 필요합니다.",
          "cameraPermission": "방문 기록을 위해 카메라 접근이 필요합니다."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "편집한 사진을 갤러리에 저장하기 위해 접근이 필요합니다.",
          "savePhotosPermission": "편집한 사진을 갤러리에 저장하기 위해 접근이 필요합니다."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "69501247-adff-48eb-9eba-c424ddd9b5f0"
      }
    }
  }
}

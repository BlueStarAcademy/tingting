{
  "name": "tingting",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "mobile": "npm run start --workspace=mobile",
    "typecheck": "npm run typecheck --workspace=mobile",
    "build:shared": "npm run build --workspace=@tingting/shared",
    "build:api": "npm run build:shared && npm run build --workspace=@tingting/api",
    "start:api": "npm run start --workspace=@tingting/api",
    "build:web": "npm run build:shared && npm run export:web --workspace=mobile && node scripts/write-web-config.js",
    "start:web": "node scripts/serve-web.js"
  },
  "devDependencies": {
    "serve": "^14.2.4"
  },
  "dependencies": {
    "expo-router": "~56.2.11"
  }
}
